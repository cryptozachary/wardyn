{
  "name": "wardyn",
  "version": "0.1.0",
  "description": "Self-hosted agent gateway with LLM skill runtime",
  "author": "Zach Lipscomb",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "ts-node --esm src/Gateway.ts",
    "build": "tsc -p tsconfig.json && node scripts/postbuild.mjs",
    "start": "node dist/src/Gateway.js",
    "store-key": "npm run build && node dist/scripts/storeKey.js",
    "backup": "npx tsx scripts/backup.ts",
    "restore": "npx tsx scripts/restore.ts",
    "doctor": "npx tsx scripts/doctor.ts",
    "pair": "npx tsx scripts/pair.ts",
    "test": "npx tsx tests/security.test.ts && npx tsx tests/integration.test.ts && npx tsx tests/readiness.test.ts",
    "test:security": "npx tsx tests/security.test.ts",
    "test:integration": "npx tsx tests/integration.test.ts",
    "test:readiness": "npx tsx tests/readiness.test.ts",
    "smoke": "npx tsx tests/smoke.test.ts",
    "electron": "npm run build && electron dist/electron/main.js",
    "electron:dev": "electron dist/electron/main.js",
    "fetch-node": "node scripts/fetch-node.mjs",
    "pack": "npm run build && npm run fetch-node && electron-builder --dir",
    "dist": "npm run build && npm run fetch-node && electron-builder"
  },
  "build": {
    "appId": "com.wardyn.app",
    "productName": "Wardyn",
    "asar": false,
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "skills",
        "to": "skills",
        "filter": ["**/*"]
      },
      {
        "from": "electron/node-runtime",
        "to": "node-runtime",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "electron/assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/assets/icon.ico",
      "uninstallerIcon": "electron/assets/icon.ico",
      "installerHeaderIcon": "electron/assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "electron/assets/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "electron/assets/icon.png",
      "category": "Utility"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.wardyn.local/",
        "channel": "latest"
      }
    ]
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "axios": "^1.13.6",
    "baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.8.0",
    "body-parser": "^1.20.2",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "hyperliquid": "^1.7.7",
    "isolated-vm": "^6.1.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.58.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/ws": "^8.18.1",
    "electron": "^32.3.3",
    "electron-builder": "^26.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "optionalDependencies": {
    "electron-updater": "^6.3.9"
  }
}
