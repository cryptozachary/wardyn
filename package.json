{
  "name": "secure-claw",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/src/Gateway.js",
  "scripts": {
    "dev": "ts-node --esm src/Gateway.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/Gateway.js",
    "store-key": "npm run build && node dist/scripts/storeKey.js",
    "backup": "tsx scripts/backup.ts",
    "restore": "tsx scripts/restore.ts",
    "doctor": "tsx scripts/doctor.ts",
    "pair": "tsx scripts/pair.ts",
    "test": "tsx tests/security.test.ts && tsx tests/integration.test.ts",
    "test:security": "tsx tests/security.test.ts",
    "test:integration": "tsx tests/integration.test.ts",
    "smoke": "tsx tests/smoke.test.ts"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "axios": "^1.13.6",
    "baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.8.0",
    "body-parser": "^1.20.2",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "hyperliquid": "^1.7.7",
    "isolated-vm": "^6.1.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.58.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
